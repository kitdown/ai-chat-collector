{
  "manifest_version": 3,
  "name": "AI Chat Collector",
  "version": "2.0.0",
  "description": "Automatically saves your AI chat links from Claude, ChatGPT, and Grok. Smart tags, random chat, auto-cleanup.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://grok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/chat/*",
        "https://chatgpt.com/c/*",
        "https://grok.com/c/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
